# ─── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Stellar / Soroban Network ────────────────────────────────
# Options: local | testnet | mainnet
STELLAR_NETWORK=testnet

# Soroban RPC endpoint
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Stellar Horizon API
HORIZON_URL=https://horizon-testnet.stellar.org

# ─── Smart Contract IDs ───────────────────────────────────────
# Populated after running scripts/deploy.sh
RECOVERY_WALLET_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4
GUARDIAN_REGISTRY_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC5
MULTISIG_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC6

# ─── Admin / Deployer Keypair ─────────────────────────────────
# The Stellar secret key used to deploy contracts and sign admin txs
# Generate with: npx ts-node scripts/generate-keypair.ts
ADMIN_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ADMIN_PUBLIC_KEY=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Authentication ───────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# ─── Notifications (optional) ─────────────────────────────────
# Email provider (sendgrid | smtp | none)
EMAIL_PROVIDER=none
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@recovery-wallet.example.com

# ─── Database (optional — for off-chain indexing) ─────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recovery_wallet

# ─── Redis (optional — for caching / job queues) ──────────────
REDIS_URL=redis://localhost:6379

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
